rules_version = '2';

// Satya Power Technologies — Firestore security rules
// Admin panel uses Firebase Auth (email/password). Any signed-in user is
// treated as an admin since admin accounts are provisioned manually in the
// Firebase console. Public visitors get read access to content collections
// and may submit inquiries.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ---------- Public content (managed in the admin panel) ----------
    match /products/{id} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /brands/{id} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /gallery/{id} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    // ---------- Site settings ----------
    match /settings/{id} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    // ---------- Inquiries (contact form) ----------
    // Anyone can submit. Only admins can read / update status / delete.
    match /inquiries/{id} {
      allow read: if isSignedIn();
      allow create: if
        request.resource.data.keys().hasAll(['name', 'createdAt']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 200;
      allow update, delete: if isSignedIn();
    }

    // ---------- Default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
