rules_version = '2';

// Satya Power Technologies — Storage security rules
// Public read for all assets used on the website. Only signed-in admin
// users can upload, update or delete files. Uploads are restricted to
// images under 5 MB to prevent abuse.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // Product images
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && isImage() && isUnder5MB();
    }

    // Brand logos
    match /brands/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && isImage() && isUnder5MB();
    }

    // Gallery images
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && isImage() && isUnder5MB();
    }

    // Generic public assets (hero, settings, etc.)
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && isImage() && isUnder5MB();
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
